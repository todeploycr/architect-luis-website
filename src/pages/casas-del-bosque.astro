---
import Layout from '@/layouts/MainLayout.astro';

import bosque1 from '@/assets/img/proyectos/casas-del-bosque/bosque-1.png';
import bosque2 from '@/assets/img/proyectos/casas-del-bosque/bosque-2.png';
import bosque3 from '@/assets/img/proyectos/casas-del-bosque/bosque-3.png';
import bosque4 from '@/assets/img/proyectos/casas-del-bosque/bosque-4.png';
import bosque5 from '/public/bosque-5.png';
---

<Layout
  title="Casas del Bosque — Proyecto Residencial de Alquiler en Nosara, Guanacaste | LARQ"
  description="Casas del Bosque es un conjunto residencial para renta en Nosara, Guanacaste. Estilo contemporáneo costero con materiales naturales, madera y conexión total con el entorno. Construido en 2023."
  image="https://larqcr.com/_astro/bosque-2.DJdXF9FV.png"
  type="article"
>

  <!-- ══════════════════════════════════════
       HERO — imagen fullscreen
  ══════════════════════════════════════ -->
  <section class="relative w-full h-screen overflow-hidden">
    <img
      src={bosque5.src}
      alt="Casas del Bosque"
      class="w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-[#3D3635]/25"></div>

    <!-- back nav -->
    <a
      href="/proyectos"
      class="absolute top-6 left-6 md:top-10 md:left-10 flex items-center gap-2
             text-white/80 hover:text-white text-xs tracking-[0.2em] uppercase
             transition-colors duration-300 group"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
           fill="none" stroke="currentColor" stroke-width="2"
           stroke-linecap="round" stroke-linejoin="round"
           class="transition-transform duration-300 group-hover:-translate-x-1">
        <path d="M19 12H5M5 12l7 7M5 12l7-7"/>
      </svg>
      Proyectos
    </a>

    <!-- título anclado al fondo izquierdo -->
    <div class="absolute bottom-10 left-6 md:bottom-14 md:left-12 lg:left-16">
      <p class="text-[#E2C200] text-[10px] md:text-xs font-medium tracking-[0.35em] uppercase mb-3">
        Residencial
      </p>
      <h1 class="font-serif font-normal text-white text-5xl md:text-7xl lg:text-8xl leading-none tracking-tight">
        Casas del Bosque
      </h1>
      <p class="text-white/50 text-xs md:text-sm mt-3 tracking-widest uppercase">
        Nosara, Guanacaste &nbsp;·&nbsp; 2023
      </p>
    </div>
  </section>


  <!-- ══════════════════════════════════════
       TEXTO — descripción editorial
  ══════════════════════════════════════ -->
  <section class="bg-[#FAF7F2] py-20 md:py-28 lg:py-36">
    <div class="max-w-5xl mx-auto px-6 md:px-12 lg:px-16">

      <div class="flex items-center gap-4 mb-10 md:mb-14">
        <span class="block w-8 h-px bg-[#E2C200]"></span>
        <span class="text-[#E2C200] text-[10px] font-medium tracking-[0.4em] uppercase">
          El Proyecto
        </span>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-20 items-start">
        <h2 class="font-serif font-normal text-[#3D3635] text-3xl md:text-4xl lg:text-5xl leading-snug">
          Contemporáneo, costero, integrado al entorno natural.
        </h2>
        <div class="space-y-5 text-[#3D3635]/70 text-sm md:text-base leading-relaxed lg:pt-2">
          <p>
            Casas del bosque es un proyecto residencial de alquiler ubicado en Nosara,
            Guanacaste, desarrollado a partir de la necesidad del cliente de aprovechar
            su terreno mediante la creación de espacios destinados a renta.
          </p>
          <p>
            El concepto arquitectónico se basa en un estilo contemporáneo con influencia
            playera, buscando integrarse de manera armónica con el entorno natural. Para
            ello, se emplea una paleta de colores neutros y cálidos, junto con materiales
            y texturas naturales como la madera, que aportan calidez y autenticidad al proyecto.
          </p>
          <p>
            La propuesta prioriza la conexión con el exterior, la ventilación e iluminación
            natural, generando espacios confortables, funcionales y atractivos para usuarios
            que buscan una experiencia de estancia ligada al paisaje y al estilo de vida
            costero característico de Nosara.
          </p>

          <div class="pt-6 border-t border-[#3D3635]/10 grid grid-cols-2 gap-y-4 gap-x-8 text-xs">
            <div>
              <p class="text-[#3D3635]/40 tracking-widest uppercase mb-1">Ubicación</p>
              <p class="text-[#3D3635] font-medium">Nosara, Guanacaste</p>
            </div>
            <div>
              <p class="text-[#3D3635]/40 tracking-widest uppercase mb-1">Año</p>
              <p class="text-[#3D3635] font-medium">2023</p>
            </div>
            <div>
              <p class="text-[#3D3635]/40 tracking-widest uppercase mb-1">Tipología</p>
              <p class="text-[#3D3635] font-medium">Residencial · Alquiler</p>
            </div>
            <div>
              <p class="text-[#3D3635]/40 tracking-widest uppercase mb-1">Estado</p>
              <p class="text-[#3D3635] font-medium">Construido</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════
       GALERÍA — grid limpio 5 imágenes
       Layout distinto a los anteriores:
       · Fila 1: 2/3 izquierda | 1/3 derecha    (img 2 + img 3)
       · Fila 2: 1/3 | 1/3 | 1/3  tres iguales  (img 4 + img 5 + bloque neutro)
       Todas las celdas con altura fija por fila → encaje perfecto
  ══════════════════════════════════════ -->
  <section class="bg-[#FAF7F2] pb-24 md:pb-32 lg:pb-40">
    <div class="max-w-7xl mx-auto px-4 md:px-8 space-y-2 md:space-y-3">

      <!-- Fila 1: imagen principal 2/3 + imagen secundaria 1/3 -->
      <div class="grid grid-cols-1 sm:grid-cols-[2fr_1fr] gap-2 md:gap-3">
        <div class="overflow-hidden">
          <img
            src={bosque1.src}
            alt="Casas del Bosque — Vista 2"
            class="w-full h-[56vw] sm:h-[55vh] md:h-[62vh] object-cover hover:scale-[1.02] transition-transform duration-700"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src={bosque3.src}
            alt="Casas del Bosque — Vista 3"
            class="w-full h-[56vw] sm:h-[55vh] md:h-[62vh] object-cover hover:scale-[1.02] transition-transform duration-700"
          />
        </div>
      </div>

      <!-- Fila 2: tres columnas iguales, altura uniforme -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-2 md:gap-3">
        <div class="overflow-hidden">
          <img
            src={bosque4.src}
            alt="Casas del Bosque — Vista 4"
            class="w-full h-[50vw] sm:h-64 md:h-72 object-cover hover:scale-[1.03] transition-transform duration-700"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src={bosque5.src}
            alt="Casas del Bosque — Vista 5"
            class="w-full h-[50vw] sm:h-64 md:h-72 object-cover hover:scale-[1.03] transition-transform duration-700"
          />
        </div>
        <div class="overflow-hidden">
          <img
            src={bosque2.src}
            alt="Casas del Bosque — Vista 5"
            class="w-full h-[50vw] sm:h-64 md:h-72 object-cover hover:scale-[1.03] transition-transform duration-700"
          />
        </div>
      </div>

    </div>
  </section>


  <!-- ══════════════════════════════════════
       FOOTER CTA
  ══════════════════════════════════════ -->
  <section class="bg-[#3D3635] py-16 md:py-20">
    <div class="max-w-5xl mx-auto px-6 md:px-12 flex flex-col sm:flex-row items-center justify-between gap-6">
      <p class="font-serif font-normal text-white/60 text-lg md:text-xl italic">
        ¿Tienes un proyecto en mente?
      </p>
      <div class="flex items-center gap-6">
        <a
          href="/projects-page"
          class="text-white/50 hover:text-white text-xs tracking-[0.25em] uppercase transition-colors duration-200"
        >
          Ver todos los proyectos
        </a>
        <a
          href="/contact"
          class="px-6 py-3 bg-[#E2C200] text-white text-xs tracking-[0.2em] uppercase font-medium
                 hover:bg-[#c9ac00] transition-colors duration-200"
        >
          Conversemos
        </a>
      </div>
    </div>
  </section>

</Layout>
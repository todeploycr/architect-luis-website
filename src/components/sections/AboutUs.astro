---
// src/components/sections/AboutUs.astro
import aboutPhoto from '@/assets/img/about-us.png';
---

<section id="nosotros" class="bg-[#FAF7F2] overflow-hidden">

  <!-- ── BLOQUE 1: Hero intro ───────────────────────────────── -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 pt-12 sm:pt-16 lg:pt-20 pb-10 sm:pb-14 lg:pb-16 grid lg:grid-cols-2 gap-8 sm:gap-10 lg:gap-12 items-center">

    <div class="fade-left">
      <span class="inline-block text-[10px] tracking-[0.4em] uppercase font-mono text-[#3D3635]/50 mb-4 sm:mb-6">
        Sobre la firma
      </span>
      <h2 class="font-serif text-3xl sm:text-4xl md:text-5xl text-[#3D3635] leading-[1.15] mb-6 sm:mb-8">
        Arquitectura<br />
        <span class="italic text-[#E2C200]">con propósito</span>
      </h2>
      <p class="text-[#3D3635]/70 text-[0.9rem] sm:text-[0.97rem] leading-[1.8] sm:leading-[1.9] font-serif mb-4 sm:mb-6">
        LARQ es una firma de arquitectura fundada por <strong class="text-[#3D3635] font-semibold">Linda y Luis</strong>, arquitectos licenciados desde 2020. Nuestra relación profesional se consolidó durante la etapa universitaria, donde desarrollamos y establecimos una metodología de trabajo basada en el análisis técnico, la precisión en el diseño y una visión estratégica del proyecto.
      </p>
      <p class="text-[#3D3635]/70 text-[0.9rem] sm:text-[0.97rem] leading-[1.8] sm:leading-[1.9] font-serif">
        Originarios de Guanacaste, hemos desarrollado proyectos en distintas regiones de Costa Rica, con mayor presencia en <strong class="text-[#3D3635] font-semibold">Heredia y Guanacaste</strong>, abordando cada encargo con una perspectiva integral que equilibra contexto, funcionalidad y valor a largo plazo.
      </p>
    </div>

    <div class="relative fade-right mt-2 sm:mt-0">
      <div class="absolute -top-4 -right-4 w-full h-full border border-[#E2C200]/40 pointer-events-none z-0"></div>
      <img
        src={aboutPhoto.src}
        alt="Linda y Luis — Fundadores LARQ Arquitectura"
        class="w-full h-70 sm:h-90 lg:h-120 object-cover relative z-10"
      />
      <div class="absolute bottom-0 left-0 z-20 bg-[#3D3635] text-white px-4 sm:px-6 py-3 sm:py-4">
        <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-[#E2C200]/70 mb-0.5">Fundación</p>
        <p class="font-serif text-2xl sm:text-3xl font-bold leading-none">2020</p>
      </div>
    </div>
  </div>

  <!-- ── SEPARADOR ─────────────────────────────────────────── -->
  <div class="w-full h-px bg-[#3D3635]/10"></div>

  <!-- ── BLOQUE 2: Filosofía — continuación natural ─────────── -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-12 sm:py-16 lg:py-20">
    <div class="grid lg:grid-cols-[200px_1fr] gap-8 sm:gap-12 lg:gap-16 items-start fade-up">

      <div class="lg:pt-2">
        <span class="font-mono text-[10px] tracking-[0.4em] uppercase text-[#3D3635]/40">
          Nuestra filosofía
        </span>
        <div class="mt-3 sm:mt-4 w-10 h-px bg-[#3D3635]/20"></div>
      </div>

      <div>
        <p class="font-serif text-[#3D3635]/70 text-[0.9rem] sm:text-[0.97rem] leading-[1.8] sm:leading-[1.9] mb-4 sm:mb-6">
          Nos especializamos en el diseño de viviendas, arquitectura bioclimática y arquitectura biofílica, integrando criterios de eficiencia ambiental, adaptación climática y calidad espacial. Asimismo, contamos con experiencia en proyectos de oficinas, comercio y retail, donde combinamos funcionalidad, identidad y optimización del espacio para potenciar la experiencia del usuario y el valor del proyecto.
        </p>
        <p class="font-serif text-[#3D3635]/70 text-[0.9rem] sm:text-[0.97rem] leading-[1.8] sm:leading-[1.9] mb-8 sm:mb-10">
          Complementamos nuestro enfoque con el diseño interno de los espacios (interiorismo), cuidando cada detalle para lograr coherencia entre arquitectura, materialidad y atmósfera. En LARQ entendemos la arquitectura como un proceso completo. Acompañamos a nuestros clientes desde la conceptualización hasta la ejecución, garantizando claridad técnica, gestión eficiente y resultados alineados con los objetivos planteados.
        </p>

        <div class="border-l-2 border-[#E2C200] pl-4 sm:pl-6">
          <p class="font-serif text-[#3D3635] text-lg sm:text-xl md:text-2xl leading-snug italic">
            Diseñamos con rigor.<br />
            <span class="not-italic font-semibold">Creamos experiencias que se habitan.</span>
          </p>
        </div>
      </div>

    </div>
  </div>
  
<!-- ── FRANJA FINAL ───────────────────────────────────────── -->
  <div class="border-t border-[#3D3635]/10 bg-[#3D3635]/5">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-4 sm:py-5 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 sm:gap-3">
      <span class="font-mono text-[10px] tracking-[0.35em] uppercase text-[#3D3635]/40">LARQ Arquitectura</span>
      <div class="flex flex-wrap items-center gap-3 sm:gap-5">
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#3D3635]/30">Guanacaste · Heredia · Costa Rica</span>
        <div class="w-1 h-1 rounded-full bg-[#E2C200] hidden sm:block"></div>
        <span class="font-mono text-[10px] tracking-[0.2em] uppercase text-[#3D3635]/30">Desde 2020</span>
      </div>
    </div>
  </div>

  <!-- ── BLOQUE 3: Especialidades — fondo oscuro al final ───── -->
  <div class="bg-[#3D3635] py-12 sm:py-16 lg:py-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">

      <div class="flex items-center gap-4 mb-8 sm:mb-12 lg:mb-14 fade-up">
        <div class="h-px w-15 bg-[#E2C200]"></div>
        <span class="font-mono text-[10px] tracking-[0.4em] uppercase text-[#E2C200]">Especialidades</span>
      </div>

      <div class="grid sm:grid-cols-2 gap-px bg-white/10 fade-up">

        <div class="bg-[#3D3635] p-6 sm:p-8 hover:bg-[#2e2928] transition-colors duration-300 group">
          <div class="w-8 h-px bg-[#E2C200] mb-4 sm:mb-6 group-hover:w-14 transition-all duration-300"></div>
          <h3 class="font-serif text-white text-base sm:text-lg mb-2 sm:mb-3">Vivienda · Bioclimática · Biofílica</h3>
          <p class="text-white/50 text-xs sm:text-sm leading-relaxed font-serif">
            Diseño de viviendas integrando criterios de eficiencia ambiental, adaptación climática y calidad espacial. Arquitectura que respira con su entorno.
          </p>
        </div>

        <div class="bg-[#3D3635] p-6 sm:p-8 hover:bg-[#2e2928] transition-colors duration-300 group">
          <div class="w-8 h-px bg-[#E2C200] mb-4 sm:mb-6 group-hover:w-14 transition-all duration-300"></div>
          <h3 class="font-serif text-white text-base sm:text-lg mb-2 sm:mb-3">Oficinas · Comercio · Retail</h3>
          <p class="text-white/50 text-xs sm:text-sm leading-relaxed font-serif">
            Espacios comerciales donde funcionalidad, identidad y optimización potencian la experiencia del usuario y el valor del proyecto.
          </p>
        </div>

        <div class="bg-[#3D3635] p-6 sm:p-8 hover:bg-[#2e2928] transition-colors duration-300 group">
          <div class="w-8 h-px bg-[#E2C200] mb-4 sm:mb-6 group-hover:w-14 transition-all duration-300"></div>
          <h3 class="font-serif text-white text-base sm:text-lg mb-2 sm:mb-3">Interiorismo</h3>
          <p class="text-white/50 text-xs sm:text-sm leading-relaxed font-serif">
            Diseño interno que cuida cada detalle para lograr coherencia entre arquitectura, materialidad y atmósfera.
          </p>
        </div>

        <div class="bg-[#3D3635] p-6 sm:p-8 hover:bg-[#2e2928] transition-colors duration-300 group">
          <div class="w-8 h-px bg-[#E2C200] mb-4 sm:mb-6 group-hover:w-14 transition-all duration-300"></div>
          <h3 class="font-serif text-white text-base sm:text-lg mb-2 sm:mb-3">Proceso Integral</h3>
          <p class="text-white/50 text-xs sm:text-sm leading-relaxed font-serif">
            Acompañamiento desde la conceptualización hasta la ejecución, garantizando claridad técnica y gestión eficiente.
          </p>
        </div>

      </div>
    </div>
  </div>

  

</section>

<style>
  .fade-left  { opacity: 0; transform: translateX(-30px); }
  .fade-right { opacity: 0; transform: translateX(30px); }
  .fade-up    { opacity: 0; transform: translateY(20px); }

  .fade-left.visible,
  .fade-right.visible,
  .fade-up.visible {
    transition: opacity 0.8s cubic-bezier(0.16,1,0.3,1), transform 0.8s cubic-bezier(0.16,1,0.3,1);
    opacity: 1;
    transform: none;
  }

  .fade-right.visible { transition-delay: 0.15s; }
</style>

<script>
  const io = new IntersectionObserver(
    (entries) => entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        io.unobserve(e.target);
      }
    }),
    { threshold: 0.1, rootMargin: '-50px' }
  );
  document.querySelectorAll('.fade-left, .fade-right, .fade-up')
    .forEach(el => io.observe(el));
</script>